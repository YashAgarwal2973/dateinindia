# Required environment variables for DateInIndia

# ── Supabase (auto-populated by Bolt) ──────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# ── Razorpay (get from razorpay.com/app/keys) ──────────────────────────────
# NEXT_PUBLIC_ key is the publishable key — safe to expose to the browser.
# It identifies your account when opening the checkout modal.
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_REPLACE_ME

# Server-side only — used by /api/create-order to create orders via Razorpay API.
RAZORPAY_KEY_ID=rzp_test_REPLACE_ME

# Secret key — NEVER expose this publicly. Used by /api/create-order and
# the verify-payment edge function to sign/verify HMAC payment signatures.
RAZORPAY_SECRET_KEY=REPLACE_ME

# ── Notes ──────────────────────────────────────────────────────────────────
# RAZORPAY_SECRET_KEY must also be added as a Supabase Edge Function secret
# so the verify-payment edge function can verify HMAC signatures.
# In the Supabase dashboard: Project Settings → Edge Functions → Secrets
# Add: RAZORPAY_SECRET_KEY = <your_secret_key>
